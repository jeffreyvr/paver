{
  "name": "paver",
  "version": "0.0.1",
  "description": "Block based drag and drop editor made with Alpine.js.",
  "scripts": {
    "dev": "open http://localhost:8000 && php -S localhost:8000 -t ./tests/localhost",
    "start-server": "php -S localhost:8000 -t ./tests/localhost",
    "stop-server": "lsof -t -i:8000 | xargs kill -9",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --headless",
    "test": "npm run start-server & npm run cypress:run && npm run stop-server",
    "build:js": "vite build --mode paver && vite build --mode frame",
    "build:css": "postcss resources/css/paver.css -o assets/css/paver.css && postcss resources/css/frame.css -o assets/css/frame.css",
    "build": "npm run build:js && npm run build:css",
    "watch": "vite build --watch --mode paver"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paver/paver.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/paver/paver/issues"
  },
  "homepage": "https://github.com/paver/paver#readme",
  "devDependencies": {
    "cssnano": "^8.0.2",
    "cypress": "^13.14.1",
    "postcss": "^8.4.41",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-prefixer": "^3.0.0",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@alpinejs/morph": "^3.14.1",
    "alpinejs": "^3.14.1",
    "sortablejs": "^1.15.2",
    "tippy.js": "^6.3.7"
  }
}