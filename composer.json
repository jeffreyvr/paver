{
  "name": "jeffreyvanrossum/paver",
  "description": "Block based drag and drop editor for developers.",
  "license": "MIT",
  "authors": [
    {
      "name": "Jeffrey van Rossum",
      "email": "jeffrey@vanrossum.dev"
    }
  ],
  "require": {
    "php": "^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.4",
    "spatie/ray": "^1.36",
    "spatie/x-ray": "^1.1",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Jeffreyvr\\Paver\\": "src"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "scripts": {
    "format": "./vendor/bin/pint ./src/",
    "x-ray": "./vendor/bin/x-ray .",
    "prepare": [
      "@x-ray",
      "@format",
      "npx mix --production"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    },
    "platform": {
      "php": "8.2.0"
    }
  }
}
